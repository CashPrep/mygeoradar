# OpenAI
OPENAI_API_KEY=sk-...

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Resend (email)
# Get your API key at resend.com/api-keys
# IMPORTANT: Add mygeoradar@gmail.com as a verified sender in Resend dashboard
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=MyGeoRadar <mygeoradar@gmail.com>

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Dashboard
DASHBOARD_SECRET=your-secret-here

# App URL
NEXT_PUBLIC_APP_URL=https://www.mygeoradar.com

# Scan price in cents
SCAN_PRICE_CENTS=100

# Cron secret — set this in Vercel env vars, then add to vercel.json cron headers
# Generate any random string: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here
