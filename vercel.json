{
  "crons": [
    {
      "path": "/api/email/send-scheduled",
      "schedule": "0 10 * * *"
    }
  ],
  "redirects": [
    { "source": "/:path*", "has": [{ "type": "host", "value": "mygeoradar.com" }], "destination": "https://www.mygeoradar.com/:path*", "permanent": true },
    { "source": "/scan", "destination": "/playbook", "permanent": true },
    { "source": "/scan/:path*", "destination": "/playbook", "permanent": true },
    { "source": "/dentists", "destination": "/industries/dentists", "permanent": true },
    { "source": "/plumbers", "destination": "/industries/plumbers", "permanent": true },
    { "source": "/lawyers", "destination": "/industries/lawyers", "permanent": true },
    { "source": "/restaurants", "destination": "/industries/restaurants", "permanent": true },
    { "source": "/med-spas", "destination": "/industries/med-spas", "permanent": true },
    { "source": "/chiropractors", "destination": "/industries/chiropractors", "permanent": true },
    { "source": "/contractors", "destination": "/industries/contractors", "permanent": true },
    { "source": "/real-estate-agents", "destination": "/industries/real-estate-agents", "permanent": true }
  ],
  "headers": [
    {
      "source": "/downloads/found-by-ai-playbook.html",
      "headers": [
        { "key": "Content-Disposition", "value": "attachment; filename=\"Found-by-AI-Playbook.html\"" },
        { "key": "Content-Type", "value": "text/html" }
      ]
    },
    {
      "source": "/downloads/ai-visibility-checklist.html",
      "headers": [
        { "key": "Content-Disposition", "value": "attachment; filename=\"AI-Visibility-Checklist.html\"" },
        { "key": "Content-Type", "value": "text/html" }
      ]
    },
    {
      "source": "/downloads/prompt-pack.html",
      "headers": [
        { "key": "Content-Disposition", "value": "attachment; filename=\"AI-Audit-Prompt-Pack.html\"" },
        { "key": "Content-Type", "value": "text/html" }
      ]
    },
    {
      "source": "/downloads/30-day-action-plan.html",
      "headers": [
        { "key": "Content-Disposition", "value": "attachment; filename=\"30-Day-AI-Visibility-Action-Plan.html\"" },
        { "key": "Content-Type", "value": "text/html" }
      ]
    }
  ]
}
