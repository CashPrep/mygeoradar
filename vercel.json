{
  "crons": [
    {
      "path": "/api/email/send-scheduled",
      "schedule": "0 10 * * *"
    }
  ],
  "functions": {
    "app/api/scan/process/route.ts": { "maxDuration": 300 },
    "app/api/scrape/route.ts":        { "maxDuration": 60  },
    "app/api/snapshot/route.ts":      { "maxDuration": 60  }
  },
  "headers": [
    {
      "source": "/downloads/found-by-ai-playbook.html",
      "headers": [
        { "key": "Content-Disposition", "value": "attachment; filename=\"Found-by-AI-Playbook.html\"" },
        { "key": "Content-Type", "value": "text/html" }
      ]
    },
    {
      "source": "/downloads/ai-visibility-checklist.html",
      "headers": [
        { "key": "Content-Disposition", "value": "attachment; filename=\"AI-Visibility-Checklist.html\"" },
        { "key": "Content-Type", "value": "text/html" }
      ]
    },
    {
      "source": "/downloads/prompt-pack.html",
      "headers": [
        { "key": "Content-Disposition", "value": "attachment; filename=\"AI-Audit-Prompt-Pack.html\"" },
        { "key": "Content-Type", "value": "text/html" }
      ]
    },
    {
      "source": "/downloads/30-day-action-plan.html",
      "headers": [
        { "key": "Content-Disposition", "value": "attachment; filename=\"30-Day-AI-Visibility-Action-Plan.html\"" },
        { "key": "Content-Type", "value": "text/html" }
      ]
    }
  ]
}
